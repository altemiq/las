<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0;net8.0</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\IO.Las.DataFrame\IO.Las.DataFrame.csproj" />
  </ItemGroup>
  
  <Choose>
    <When Condition="$([System.OperatingSystem]::IsLinux())">
      <ItemGroup>
        <PackageReference Include="Polars.NET.Native.linux-arm64" />
        <PackageReference Include="Polars.NET.Native.linux-x64" />
      </ItemGroup>
    </When>
    <When Condition="$([System.OperatingSystem]::IsWindows())">
      <ItemGroup>
        <PackageReference Include="Polars.NET.Native.win-x64" />
      </ItemGroup>
    </When>
    <When Condition="$([System.OperatingSystem]::IsMacOS())">
      <ItemGroup>
        <PackageReference Include="Polars.NET.Native.osx-arm64" />
      </ItemGroup>
    </When>
  </Choose>

  <ItemGroup>
    <EmbeddedResource Include="..\..\data\las\fusa.las" />
  </ItemGroup>

</Project>
