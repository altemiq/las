<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0;net8.0</TargetFrameworks>
    <TargetFrameworks Condition=" '$(NetCoreOnly)' != 'true' ">$(TargetFrameworks);net472</TargetFrameworks>
    <MeziantouPolyfill_IncludedPolyfills>
      $(MeziantouPolyfill_IncludedPolyfills)|
      M:System.IO.Stream.DisposeAsync()|
      T:System.Diagnostics.UnreachableException|
    </MeziantouPolyfill_IncludedPolyfills>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\IO.Las.Compression\IO.Las.Compression.csproj" />
  </ItemGroup>
  
  <ItemGroup>
    <EmbeddedResource Include="..\..\data\laz\fusa.laz" />
    <EmbeddedResource Include="*.laz" />
  </ItemGroup>
  
  <ItemGroup Condition=" '$(SupportLas12)' != 'true' ">
    <!-- Remove color point data records for versions below 1.2 -->
    <Compile Remove="**\*Color*.cs" />
  </ItemGroup>

  <Choose>
    <When Condition=" '$(SupportLas14)' == 'true' ">
      <ItemGroup>
        <Compile Include="..\IO.Las.Tests\ExtraBytesItemExtensions.cs" />
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup>
        <!-- Remove extended point data records for versions below 1.4 -->
        <Compile Remove="**\ExtendedVariableLengthRecord*.cs" />
        <Compile Remove="**\*ExtraBytes*.cs" />
        <Compile Remove="**\*Layered*.cs" />
      </ItemGroup>
    </Otherwise>
  </Choose>

</Project>
